<div class="container">
    <div class="auth-layout">
        <section class="auth-panel auth-panel-highlight">
            <p class="auth-kicker">DLSU Eats</p>
            <h1>Welcome back</h1>
            <p class="text-muted">Sign in to continue exploring trusted reviews and share your latest food finds near DLSU.</p>
            <ul class="auth-benefits">
                <li>Track restaurants you visited</li>
                <li>Write and manage your reviews</li>
                <li>Get updates from restaurant owners</li>
            </ul>
        </section>

        <section class="auth-panel">
            <h2 class="text-center">Login to DLSU Eats</h2>

            {{#if error}}
            <div class="alert alert-error">{{error}}</div>
            {{/if}}

            <form action="/auth/login" method="POST" id="login-form" novalidate>
                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" class="form-control" placeholder="your.email@dlsu.edu.ph" required>
                    <p class="error-msg" id="email-error"></p>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required minlength="6">
                    <p class="error-msg" id="password-error"></p>
                </div>

                <div class="form-group">
                    <div class="form-checkbox">
                        <input type="checkbox" id="rememberMe" name="rememberMe" value="1">
                        <label for="rememberMe">Remember me</label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary auth-submit">Login</button>
            </form>

            <hr class="auth-divider">
            <p class="text-center">
                Don't have an account? <a href="/auth/register">Register here</a>
            </p>
        </section>
    </div>
</div>

<script>
const loginForm = document.getElementById('login-form');

function setLoginError(fieldId, message) {
    document.getElementById(fieldId + '-error').textContent = message;
}

function validateLoginForm() {
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const email = emailInput.value.trim();
    const password = passwordInput.value;
    let valid = true;

    setLoginError('email', '');
    setLoginError('password', '');

    if (!email || !emailInput.checkValidity()) {
        setLoginError('email', 'Please enter a valid email address.');
        valid = false;
    }

    if (password.length < 6) {
        setLoginError('password', 'Password must be at least 6 characters.');
        valid = false;
    }

    return valid;
}

loginForm.addEventListener('submit', function (event) {
    if (!validateLoginForm()) {
        event.preventDefault();
    }
});

['email', 'password'].forEach(function (id) {
    document.getElementById(id).addEventListener('input', validateLoginForm);
    document.getElementById(id).addEventListener('change', validateLoginForm);
});
</script>
