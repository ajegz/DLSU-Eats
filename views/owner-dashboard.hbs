<div class="container">
    <div class="dashboard-hero owner-hero">
        <div>
            <h1>Owner Dashboard</h1>
            <p class="text-muted">Welcome, {{user.name}}. Track your restaurant performance and respond to feedback quickly.</p>
        </div>
        <div class="dashboard-badge-pill">{{reviewCount}} review{{#if (gt reviewCount 1)}}s{{/if}} to manage</div>
    </div>

    {{#if error}}
    <div class="alert alert-error">{{error}}</div>
    {{/if}}

    <div class="dashboard-stats-grid">
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-value">{{restaurants.length}}</div>
            <div class="dashboard-stat-label">Managed Restaurants</div>
        </div>
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-value">{{reviewCount}}</div>
            <div class="dashboard-stat-label">Total Reviews</div>
        </div>
        <div class="dashboard-stat-card">
            <div class="dashboard-stat-value">Owner</div>
            <div class="dashboard-stat-label">{{user.name}}</div>
        </div>
    </div>

    {{#if restaurants.length}}
    <div class="dashboard-section">
        <h2>Your Restaurants</h2>
        <div class="card-grid">
            {{#each restaurants}}
            <div class="card" onclick="window.location='/restaurants/{{id}}'">
                <img src="/{{image}}" alt="{{name}}" class="card-image" onerror="this.src='https://via.placeholder.com/400x300?text={{name}}'">
                <div class="card-content">
                    <h3>{{name}}</h3>
                    <div class="card-rating">{{{stars rating}}} {{rating}}/5 ({{ratingCount}} reviews)</div>
                    <div class="card-info"><span>{{location}}</span></div>
                </div>
            </div>
            {{/each}}
        </div>
    </div>
    {{/if}}

    <div class="dashboard-section">
        <h2>Customer Reviews</h2>
        {{#if reviews.length}}
        <div class="owner-review-list">
            {{#each reviews}}
            <article class="review-card owner-review-card">
                <div class="review-header">
                    <img src="{{avatarUrl reviewer.profilePicture}}" alt="{{#if reviewer.name}}{{reviewer.name}}{{else}}Anonymous reviewer{{/if}}" class="reviewer-avatar" onerror="this.src='{{avatarUrl null}}'">
                    <div class="review-header-main">
                        <div class="review-header-top">
                            <h3><a href="/reviews/{{_id}}">{{title}}</a></h3>
                            <span class="review-date">{{date}}</span>
                        </div>
                        <div class="review-author">By {{#if reviewer.name}}{{reviewer.name}}{{else}}Anonymous reviewer{{/if}}</div>
                        <div class="card-rating">{{{stars rating}}} {{rating}}/5</div>
                        <a href="/restaurants/{{restaurant.id}}" class="review-restaurant-chip">
                            <img src="{{assetPath restaurant.image}}" alt="{{restaurant.name}}" class="review-restaurant-thumb" onerror="this.src='https://via.placeholder.com/96x96?text=Food'">
                            <span>{{restaurant.name}}</span>
                        </a>
                    </div>
                </div>
                <div class="owner-review-footer">
                    <div>
                        {{#if ownerResponse}}
                        <span class="badge badge-green">Responded</span>
                        {{else}}
                        <span class="badge badge-gold">Pending Response</span>
                        {{/if}}
                    </div>
                    <div>
                        {{#if ownerResponse}}
                        <button class="btn btn-outline" disabled>Responded</button>
                        {{else}}
                        <button class="btn btn-primary" onclick="showForm('{{_id}}', '{{title}}', '{{#if reviewer.name}}{{reviewer.name}}{{else}}Anonymous reviewer{{/if}}', '{{date}}')">Respond</button>
                        {{/if}}
                    </div>
                </div>
            </article>
            {{/each}}
        </div>
        {{else}}
        <div class="empty-state">
            <h3>No reviews yet</h3>
            <p>Your restaurants haven't received any reviews yet.</p>
        </div>
        {{/if}}
    </div>

    <div class="restaurant-detail hidden" id="response-form-container">
        <h3>Respond to Review</h3>
        <div id="review-context" class="mb-1"></div>
        <form action="/owner/reviews/__REVIEW_ID__/reply" method="POST" id="response-form">
            <div class="form-group">
                <label for="responseText">Your Response</label>
                <textarea id="responseText" name="responseText" class="form-control" placeholder="Thank the customer and address their feedback..." required style="min-height:120px;"></textarea>
            </div>
            <div class="btn-group">
                <button type="submit" class="btn btn-primary">Submit Response</button>
                <button type="button" class="btn btn-outline" onclick="hideForm()">Cancel</button>
            </div>
        </form>
    </div>
</div>

<script>
function showForm(id, title, reviewer, date) {
  document.getElementById('response-form-container').classList.remove('hidden');
  document.getElementById('review-context').innerHTML =
        `<div class="review-card owner-context-card"><strong>${title}</strong><br>By ${reviewer} on ${date}</div>`;
  document.getElementById('response-form').action = '/owner/reviews/' + id + '/reply';
  document.getElementById('response-form-container').scrollIntoView({ behavior: 'smooth' });
}
function hideForm() {
  document.getElementById('response-form-container').classList.add('hidden');
}
</script>
