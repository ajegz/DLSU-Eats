<div class="container">
    <h1>Search DLSU Eats</h1>

    <form method="GET" action="/search" class="search-form" style="margin-bottom:1.5rem;">
        <div class="search-bar">
            <input type="text" name="q" class="form-control" placeholder="Search restaurants, cuisines, reviews..." value="{{query}}" autofocus>
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
        <ul id="search-suggestions" class="search-suggestions hidden" aria-label="Search suggestions"></ul>
        <div class="filter-tags" style="margin-top:0.75rem;">
            <button type="submit" name="type" value="all" class="filter-tag {{#if (eq type 'all')}}active{{/if}}">All</button>
            <button type="submit" name="type" value="restaurants" class="filter-tag {{#if (eq type 'restaurants')}}active{{/if}}">Restaurants</button>
            <button type="submit" name="type" value="reviews" class="filter-tag {{#if (eq type 'reviews')}}active{{/if}}">Reviews</button>
        </div>
    </form>

    {{#if query}}
    <p class="search-result-count text-muted">
        {{totalCount}} result{{#if (gt totalCount 1)}}s{{/if}} for "<strong>{{query}}</strong>"
    </p>

    {{#if restaurantResults.length}}
    <section class="result-section">
        <h2>Restaurants</h2>
        <div class="search-restaurant-list">
            {{#each restaurantResults}}
            <div class="card search-result-card" onclick="window.location='/restaurants/{{id}}'">
                <img src="/{{image}}" alt="{{name}}" class="card-image" onerror="this.src='https://via.placeholder.com/400x300?text={{name}}'">
                <div class="card-content">
                    <h3>{{name}}</h3>
                    <div class="card-rating">{{{stars rating}}} {{rating}}/5</div>
                    <div class="card-tags">
                        {{campusBadge insideCampus}}
                        <span class="badge badge-gold">{{priceRange}}</span>
                        {{#each foodStyles}}<span class="badge badge-outline">{{this}}</span>{{/each}}
                    </div>
                    <div class="card-info"><span>{{location}}</span></div>
                </div>
            </div>
            {{/each}}
        </div>
    </section>
    {{/if}}

    {{#if reviewResults.length}}
    <section class="result-section" style="margin-top:2rem;">
        <h2>Reviews</h2>
        <div class="review-list">
            {{#each reviewResults}}
            <div class="review-card" onclick="window.location='/reviews/{{_id}}'">
                <div class="review-header">
                    <img src="{{avatarUrl reviewer.profilePicture}}" alt="{{#if reviewer.name}}{{reviewer.name}}{{else}}Anonymous reviewer{{/if}}" class="reviewer-avatar" onerror="this.src='{{avatarUrl null}}'">
                    <div class="review-header-main">
                        <div class="review-header-top">
                            <h3 class="review-title">{{title}}</h3>
                            <span class="review-date">{{date}}</span>
                        </div>
                        <div class="reviewer-name">Reviewed by {{#if reviewer.name}}{{reviewer.name}}{{else}}Anonymous reviewer{{/if}}</div>
                        <div class="card-rating">{{{stars rating}}} <strong>{{rating}}/5</strong></div>
                        <div class="review-restaurant">
                            {{#if restaurant}}
                            <a href="/restaurants/{{restaurant.id}}" onclick="event.stopPropagation()" class="review-restaurant-chip">
                                <img src="{{assetPath restaurant.image}}" alt="{{restaurant.name}}" class="review-restaurant-thumb" onerror="this.src='https://via.placeholder.com/96x96?text=Food'">
                                <span>{{restaurant.name}}</span>
                            </a>
                            {{else}}
                            <span class="text-muted">Restaurant unavailable</span>
                            {{/if}}
                        </div>
                    </div>
                </div>
                <p class="review-body">{{truncate body 200}}</p>
                <div class="review-footer">
                    <span>{{date}}</span>
                    <span class="icon-text"><span aria-hidden="true">👍</span><span>{{helpful}} helpful</span></span>
                    {{#if ownerResponse}}<span class="badge badge-green">Owner responded</span>{{/if}}
                </div>
            </div>
            {{/each}}
        </div>
    </section>
    {{/if}}

    {{#unless hasResults}}
    <div class="empty-state">
        <h3>No results found</h3>
        <p>Try different keywords or browse all restaurants.</p>
        <a href="/restaurants" class="btn btn-primary">Browse Restaurants</a>
    </div>
    {{/unless}}

    {{else}}
    <div class="empty-state">
        <h3>Start searching</h3>
        <p>Search for restaurants, cuisines, or food reviews around DLSU.</p>
    </div>
    {{/if}}
</div>
